# Line-ending and storage policy. Committed here so it applies to every
# clone regardless of each machine's core.autocrlf setting.

# Normalize anything Git detects as text to LF in the repository, and check
# it out with the platform-native ending.
* text=auto

# Unreal assets and large media live in Git LFS. "-text" disables EOL
# conversion, which would silently corrupt them.
*.uasset  filter=lfs diff=lfs merge=lfs -text
*.umap    filter=lfs diff=lfs merge=lfs -text
*.ubulk   filter=lfs diff=lfs merge=lfs -text
*.uexp    filter=lfs diff=lfs merge=lfs -text
*.upk     filter=lfs diff=lfs merge=lfs -text
*.udk     filter=lfs diff=lfs merge=lfs -text
*.png     filter=lfs diff=lfs merge=lfs -text
*.jpg     filter=lfs diff=lfs merge=lfs -text
*.jpeg    filter=lfs diff=lfs merge=lfs -text
*.tga     filter=lfs diff=lfs merge=lfs -text
*.bmp     filter=lfs diff=lfs merge=lfs -text
*.psd     filter=lfs diff=lfs merge=lfs -text
*.fbx     filter=lfs diff=lfs merge=lfs -text
*.wav     filter=lfs diff=lfs merge=lfs -text
*.mp3     filter=lfs diff=lfs merge=lfs -text
*.ogg     filter=lfs diff=lfs merge=lfs -text

# Binary, but small enough to leave in Git proper.
*.gif     binary
*.ico     binary
*.ttf     binary
*.otf     binary
*.dll     binary
*.lib     binary
*.pdb     binary
*.exe     binary
*.so      binary
*.dylib   binary
*.zip     binary
*.7z      binary

# Scripts whose endings matter to their interpreter.
*.sh       text eol=lf
*.command  text eol=lf
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# Unreal / project text files.
*.uproject   text
*.uplugin    text
*.ini        text
*.cs         text
*.h          text
*.hpp        text
*.cpp        text
*.inl        text
*.svg        text
